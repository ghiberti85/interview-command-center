# Supabase — obtenha em https://supabase.com/dashboard/project/<project-id>/settings/api
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-publica>

# URL da Edge Function anthropic-proxy (gerada automaticamente pelo Supabase)
VITE_AI_PROXY_URL=https://<project-id>.supabase.co/functions/v1/anthropic-proxy
